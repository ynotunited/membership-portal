# =============================================================================
# public/.htaccess – Secure deployment configuration for the public webroot
# =============================================================================

RewriteEngine On

# ── 1. HTTPS enforcement (production) ────────────────────────────────────────
# Uncomment on production after confirming SSL is active.
# RewriteCond %{HTTPS} off
# RewriteCond %{HTTP_HOST} !^localhost [NC]
# RewriteCond %{HTTP_HOST} !^127\.0\.0\.1
# RewriteRule ^(.*)$ https://%{HTTP_HOST}/gafconl-app/public/$1 [R=301,L]

# ── 2. Security headers ───────────────────────────────────────────────────────
<IfModule mod_headers.c>
    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"

    # Prevent MIME-type sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Enable XSS filter in older browsers
    Header always set X-XSS-Protection "1; mode=block"

    # Referrer policy – don't leak URLs to third parties
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions policy – disable unused browser features
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"

    # Content Security Policy
    # Allows: same-origin scripts/styles, CDNs used by the app, inline styles (Tailwind).
    # Tighten 'unsafe-inline' once Tailwind is bundled locally.
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://cdn.tailwindcss.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com 'unsafe-inline'; style-src 'self' https://fonts.googleapis.com https://cdnjs.cloudflare.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data:; connect-src 'self'; frame-ancestors 'self';"

    # HSTS – Uncomment on production once HTTPS is verified working.
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Remove PHP version leak
    Header always unset X-Powered-By
</IfModule>

# ── 3. Block direct access to PHP files in upload directories ─────────────────
# Prevents uploaded webshells from being executed.
<FilesMatch "^uploads/.*\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── 4. Block access to backup and log files in public ────────────────────────
<FilesMatch "\.(log|bak|sql|sh|env|json|lock|md|yml|yaml)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── 5. Disable directory listing ─────────────────────────────────────────────
Options -Indexes

# ── 6. Front-controller routing ──────────────────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php?/$1 [QSA,L]
